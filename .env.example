# Copy to .env and fill in. .env is gitignored.

# ── Required ────────────────────────────────────────────────────────────────
# SQLAlchemy connection string. Used by news_articles, market_data, corporate_db.
# Examples:
#   sqlite:///resonance.db
#   postgresql+psycopg2://user:pass@localhost:5432/resonance
DATABASE_URL=sqlite:///resonance.db

# ── Optional ────────────────────────────────────────────────────────────────
# news_articles log verbosity (DEBUG / INFO / WARNING / ERROR). Default: INFO
NEWS_LOG_LEVEL=INFO

# corporate_db: truthy value logs every SQL statement issued by SQLAlchemy.
ECHO_SQL=0

# market_data: default OHLCV date range when --start / --end aren't passed.
# START_DATE=2015-01-01
# END_DATE=2026-05-11
